generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum Role {
  ADMIN
  MANAGER
  CREW
  CLIENT
}

enum PropertyStatus {
  PENDING_CLIENT       // Owner a preencher dados
  PENDING_APPROVAL     // Admin a aprovar
  CONTRACT_PENDING     // Aprovada, à espera de assinatura do contrato
  ACTIVE
  INACTIVE
  MAINTENANCE
}

enum TaskType {
  CLEANING
  MAINTENANCE_PREVENTIVE
  MAINTENANCE_CORRECTIVE
  INSPECTION
  CHECK_IN
  CHECK_OUT
  TRANSFER
  SHOPPING
  LAUNDRY
  SETUP_AI_CONTEXT          // Manager fills AI assistant context during property setup
  SETUP_FIELD_INSPECTION    // Captain captures physical property data (breaker, water, quirks)
}

enum TaskStatus {
  PENDING
  NOTIFIED          // Crew was notified about task
  CONFIRMED         // Crew confirmed they'll do it
  IN_PROGRESS
  SUBMITTED         // Crew submitted report + photos
  APPROVED          // Captain approved the work
  REJECTED          // Captain rejected — needs redo or redistribute
  REDISTRIBUTED     // Reassigned to another crew member
  COMPLETED         // Legacy — kept for backward compat
}

enum CrewScoreLevel {
  SUSPENDED    // 0-49
  BASIC        // 50-149
  VERIFIED     // 150-299
  EXPERT       // 300-499
  ELITE        // 500+
}

enum CrewPayoutStatus {
  PENDING
  PROCESSING
  PAID
  FAILED
}

enum InterventionStatus {
  OPEN
  IN_PROGRESS
  RESOLVED
  ESCALATED
}

enum AiRiskLevel {
  LOW
  MEDIUM
  HIGH
}

enum ReservationStatus {
  UPCOMING
  ACTIVE
  COMPLETED
  CANCELLED
  AWAITING_REPORT
}

enum SupplierType {
  CLEANER
  PLUMBER
  ELECTRICIAN
  GENERAL
}

enum SubscriptionPlan {
  STARTER
  BASIC
  MID
  PREMIUM
}

enum Platform {
  AIRBNB
  BOOKING
  DIRECT
  OTHER
}

enum ConversationStatus {
  OPEN
  CLOSED
}

enum LeadStatus {
  NEW
  CONTACTED
  QUALIFIED
  CONVERTED
  RETAINED
  LOST
  REMARKETING
}

enum LeadSource {
  CADASTRO
  NEWSLETTER
  ONLINE
  PHONE
  WHATSAPP
  WEBSITE
  EMAIL
  REFERRAL
  SERVICE_REQUEST
  OTHER
}

enum PayoutStatus {
  SCHEDULED
  PAID
  CANCELLED
}

enum ExpenseCategory {
  CONSUMABLES
  LAUNDRY
  RENT
  UTILITIES
  SUBSCRIPTIONS
  VEHICLES
  MARKETING
  PROFESSIONAL_SERVICES
  SALARIES
  TAXES
  OTHER
}

enum ExpenseStatus {
  DRAFT
  PENDING_APPROVAL
  APPROVED
  PAID
  REJECTED
  CANCELLED
}

enum PaymentMethod {
  BANK_TRANSFER
  DIRECT_DEBIT
  CREDIT_CARD
  CASH
  BIZUM
  STRIPE_CARD
  SEPA_DEBIT
  OTHER
}

enum RecurringFrequency {
  WEEKLY
  MONTHLY
  QUARTERLY
  SEMI_ANNUAL
  ANNUAL
}

enum ConsumableType {
  LAUNDERABLE
  DISPOSABLE
  DURABLE
  WELCOME_KIT
}

enum ItemStatus {
  AVAILABLE
  DEPLOYED
  IN_TRANSIT
  WASHING
  RETURNING
  QUARANTINE
  RETIRED
}

enum MovementType {
  CHECKOUT_FROM_STORAGE
  CHECKIN_TO_PROPERTY
  PICKUP_FROM_PROPERTY
  SEND_TO_LAUNDRY
  RETURN_FROM_LAUNDRY
  RETURN_TO_STORAGE
  RETIRED
  QUARANTINED
  PURCHASE_ENTRY
}

// ── VAGF (Voice Agent Guest Feedback) ──

enum CallStatus {
  SCHEDULED
  IN_PROGRESS
  COMPLETED_SUCCESS
  COMPLETED_PARTIAL
  NOT_ANSWERED
  DECLINED
  FALLBACK_SMS_SENT
  FALLBACK_WEB_COMPLETED
  UNREACHABLE
  CANCELLED
}

enum NpsCategory {
  PROMOTER
  PASSIVE
  DETRACTOR
}

enum FeedbackSentiment {
  POSITIVE
  NEUTRAL
  NEGATIVE
  SEVERE_NEGATIVE
}

enum EscalationLevel {
  NONE
  LOW
  MEDIUM
  HIGH
  CRITICAL
}

// ── Guest Stay Chat ──

enum StayChatAuthor {
  GUEST
  AI
  MANAGER
  ADMIN
  SYSTEM
}

/// Indicates what kind of service the client signed up for.
/// Drives dashboard experience: full STR management vs one-time services only.
enum RentalIntent {
  SHORT_TERM_FULL   // Wants full platform management (Starter/Basic/Mid/Premium)
  ONE_TIME_ONLY     // Only wants to buy individual services (photography, cleaning, etc.)
  UNDECIDED         // Hasn't chosen yet — show both paths
}

enum StayChatEscalationStatus {
  NONE
  PENDING_MANAGER
  PENDING_ADMIN
  RESOLVED
}

enum ReceiptStatus {
  DRAFT
  PENDING
  PAID
  FAILED
  CANCELLED
  REFUNDED
}

enum ReceiptType {
  SUBSCRIPTION
  RENTAL_COMMISSION
  ADJUSTMENT
  SETUP_PACKAGE
  CONSUMABLES_ADDON
  LAUNDRY_SERVICE
  WELCOME_KIT
  MAINTENANCE_FEE
  REFUND
}

enum ExportStatus {
  DRAFT
  GENERATED
  UPLOADED_TO_TAXFIX
  INVOICES_RECEIVED
  COMPLETE
}

model User {
  id                 String    @id @default(cuid())
  name               String?
  email              String    @unique
  emailVerified      DateTime?
  image              String?
  password           String?
  role               Role      @default(CLIENT)
  phone              String?
  language           String    @default("en")
  birthday           DateTime?
  stripeCustomerId   String?
  subscriptionPlan   SubscriptionPlan?
  subscriptionStatus String?
  rentalIntent       RentalIntent?     // Client-only: what they signed up for
  managerId          String?
  satisfactionScore  Float?
  ltv                Float?    @default(0)
  bio                String?
  commissionRate     Float?
  // Manager compensation (configurable per manager)
  managerSubscriptionShare  Float?    // % of client subscription fee (default: 10%)
  managerCommissionShare    Float?    // % of gross rental revenue (default: 2%)
  referralCode              String?   @unique  // Manager personal referral code for landing link
  managerZone               String?   // Territory/zone (e.g. "Almunecar", "Nerja")
  // Crew compensation
  crewContractType   String?   // MONTHLY | FREELANCER
  crewMonthlyRate    Float?    // €/month (if MONTHLY)
  crewTaskRate       Float?    // €/task (if FREELANCER)
  crewHourlyRate     Float?    // €/hour (if FREELANCER, optional)
  crewSkills         String?   // JSON array: ["CLEANING","MAINTENANCE","CHECK_IN",...]
  crewAvailability   String?   // JSON: {"mon":true,"tue":true,...}
  isCaptain          Boolean   @default(false) // Crew Captain (fixed supervisor, not gig)
  stripeConnectId    String?   // Stripe Connect account for Crew payouts
  // Onboarding
  onboardingCompleted Boolean  @default(false)
  onboardingData      Json?    // wizard answers stored here
  isSuperUser        Boolean   @default(false)
  createdAt          DateTime  @default(now())
  updatedAt          DateTime  @updatedAt

  manager       User?      @relation("ManagerClients", fields: [managerId], references: [id])
  clients       User[]     @relation("ManagerClients")
  accounts      Account[]
  sessions      Session[]
  properties    Property[]
  tasks         Task[]     @relation("AssignedTasks")
  leads         Lead[]     @relation("LeadOwner")
  assignedLeads Lead[]     @relation("AssignedLeads")
  receiptsReceived     PaymentReceipt[] @relation("ClientReceipts")
  receiptsIssued       PaymentReceipt[] @relation("CreatedReceipts")
  contracts            Contract[]     @relation("ContractUser")
  clientConversations  Conversation[] @relation("ClientConversations")
  managerConversations Conversation[] @relation("ManagerConversations")
  sentMessages         Message[]      @relation("SentMessages")
  campaigns            Campaign[]     @relation("CampaignCreator")
  taxObligations       TaxObligation[]
  // Manager compensation payouts (monthly)
  managerPayouts       ManagerPayout[]            @relation("ManagerPayouts")
  // Crew system
  crewScore            CrewScore?
  crewRelationships    CrewPropertyRelationship[] @relation("CrewRelationships")
  crewPayouts          CrewPayout[]               @relation("CrewPayouts")
  captainTasks         Task[]                     @relation("CaptainTasks")
  managerInterventions CrewIntervention[]         @relation("ManagerInterventions")
  captainInterventions CrewIntervention[]         @relation("CaptainInterventions")
  notifications        Notification[]
  groupMemberships     GroupChatMember[]
  groupMessages        GroupMessage[]              @relation("GroupMessageSender")
  stayReviews          StayReview[]                @relation("StayReviewer")
  feedbackAsClient     GuestFeedback[]             @relation("ClientFeedback")
  feedbackAsCrew       GuestFeedback[]             @relation("CrewFeedback")
  stayChatsAsClient    GuestStayChat[]             @relation("ClientStayChats")
  escalatedStayChats   GuestStayChat[]             @relation("EscalatedStayChats")
  broadcasts           Broadcast[]                 @relation("BroadcastSender")
  broadcastsReceived   BroadcastRecipient[]        @relation("BroadcastRecipient")
  broadcastThreads     BroadcastReply[]            @relation("BroadcastThreadOwner")
  broadcastRepliesAuthored BroadcastReply[]        @relation("BroadcastReplyAuthor")

  // VAGF Crew fields
  guestScoreAverage    Float?            @default(0)
  guestScoreCount      Int?              @default(0)
  lastGuestScoreAt     DateTime?
  suspendedDueToFeedback Boolean         @default(false)
  suspensionReason     String?
  suspendedAt          DateTime?
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String? @db.Text
  access_token      String? @db.Text
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String? @db.Text
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

enum TaxObligationType {
  VUT_LICENSE          // Licença turística (Junta de Andalucía)
  MODELO_179           // Declaração trimestral de hóspedes (Agência Tributária)
  IRNR_MODELO_210      // Imposto de renda não-residentes (trimestral)
  NIE                  // Número de identificação de estrangeiro
  ENERGY_CERTIFICATE   // Certificado energético (10 anos)
  FISCAL_REPRESENTATIVE // Representante fiscal para não-residentes
  IBI                  // Imposto sobre bens imóveis (anual)
  OTHER
}

enum TaxObligationStatus {
  NOT_STARTED    // Ainda não iniciado
  IN_PROGRESS    // A tratar
  ACTION_REQUIRED // Falta documento/acção do cliente
  COMPLETED      // Feito para este período
  EXPIRED        // Prazo passou sem acção
  NOT_APPLICABLE // Não se aplica a este cliente
}

model TaxObligation {
  id              String              @id @default(cuid())
  userId          String              // CLIENT owner
  propertyId      String?             // opcional: algumas obrigações são por propriedade
  type            TaxObligationType
  status          TaxObligationStatus @default(NOT_STARTED)
  periodLabel     String              // ex: "Q1 2026", "2026", "Uma vez"
  dueDate         DateTime?           // próximo prazo
  completedAt     DateTime?
  documentUrl     String?             // link para PDF/comprovativo
  notes           String?             // nota interna do Admin/Manager
  handledBy       String?             // ADMIN que tratou
  createdAt       DateTime            @default(now())
  updatedAt       DateTime            @updatedAt

  user     User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  property Property? @relation(fields: [propertyId], references: [id], onDelete: SetNull)

  @@index([userId, type])
  @@index([dueDate])
  @@index([status])
}

model Property {
  id               String         @id @default(cuid())
  name             String
  address          String
  city             String
  postalCode       String?
  description      String?        @db.Text
  photos           String[]
  contractUrl      String?
  smartLockId          String?
  smartLockInstalled   Boolean   @default(false)
  smartLockProvider    String?   // e.g. "Nuki", "TTLock", "Yale"
  // ── AI Assistant context (populated during property setup) ──
  wifiSsid             String?
  wifiPassword         String?
  doorCode             String?           // Permanent door code (if not smart lock rotation)
  smartLockPassword    String?           // Current guest code
  emergencyWhatsapp    String?           // Manager's emergency WhatsApp for critical escalations
  parkingInstructions  String?   @db.Text
  checkInInstructions  String?   @db.Text
  checkOutInstructions String?   @db.Text
  appliancesInfo       String?   @db.Text // "Don't run AC + oven + heater together — trips breaker"
  breakerLocation      String?           // Where is the fuse box
  waterShutoffLocation String?           // Where is main water valve
  propertyQuirks       String[]          // List of specific quirks ("dryer is slow", "hot water takes 30s", etc.)
  guestGuideUrl        String?           // Link to full digital house manual
  bedrooms             Int?
  sizeSqm          Int?
  airbnbConnected   Boolean        @default(false)
  bookingConnected  Boolean        @default(false)
  airbnbIcalUrl     String?
  airbnbListingId   String?
  bookingIcalUrl    String?
  bookingPropertyId String?
  lastCleaningAt   DateTime?
  lastInspectionAt DateTime?
  status           PropertyStatus @default(PENDING_APPROVAL)
  houseRules       String[]       // pre-defined rule keys, e.g. ["NO_SMOKING", "QUIET_22_08"]
  commissionRate   Float          @default(17.0)
  latitude         Float?
  longitude        Float?
  ownerId          String
  createdAt        DateTime       @default(now())
  updatedAt        DateTime       @updatedAt

  owner          User               @relation(fields: [ownerId], references: [id])
  reservations   Reservation[]
  expenses       Expense[]
  monthlyReports MonthlyReport[]
  tasks          Task[]
  suppliers      SupplierProperty[]
  blockedDates   BlockedDate[]
  payouts        Payout[]
  receipts       PaymentReceipt[]
  pricingPoints  PricingDataPoint[]
  checklistItems PropertyChecklistItem[]
  taxObligations     TaxObligation[]
  contracts          Contract[]
  crewRelationships  CrewPropertyRelationship[]
  guestFeedback      GuestFeedback[]            @relation("PropertyFeedback")
  stayChats          GuestStayChat[]            @relation("PropertyStayChats")
  stayReviews        StayReview[]
  consumableItems     ConsumableItem[]
  consumableMovements ConsumableMovement[]
  consumableSetups    PropertyConsumableSetup[]

  @@index([ownerId])
  @@index([status])
}

model PaymentReceipt {
  id                    String         @id @default(cuid())
  receiptNumber         String         @unique
  type                  ReceiptType    @default(SUBSCRIPTION)

  // Parties
  clientId              String
  client                User           @relation("ClientReceipts", fields: [clientId], references: [id])
  propertyId            String?
  property              Property?      @relation(fields: [propertyId], references: [id])
  createdById           String
  createdBy             User           @relation("CreatedReceipts", fields: [createdById], references: [id])

  // Financial
  description           String         @db.Text
  grossAmount           Decimal        @db.Decimal(10,2)
  discountAmount        Decimal        @default(0) @db.Decimal(10,2)
  netAmount             Decimal        @db.Decimal(10,2)
  vatRate               Decimal        @default(21) @db.Decimal(5,2)
  vatAmount             Decimal        @db.Decimal(10,2)
  totalAmount           Decimal        @db.Decimal(10,2)
  currency              String         @default("EUR")

  // Context
  periodStart           DateTime?
  periodEnd             DateTime?
  reservationId         String?
  reservation           Reservation?   @relation(fields: [reservationId], references: [id])

  // Payment
  status                ReceiptStatus  @default(PENDING)
  isAutoGenerated       Boolean        @default(false)
  dueDate               DateTime?
  paidAt                DateTime?
  paymentMethod         PaymentMethod?
  stripePaymentIntentId String?        @unique
  stripeChargeId        String?

  // Taxfix linkage
  externalFiscalRef     String?
  externalFiscalDate    DateTime?
  taxfixExported        Boolean        @default(false)
  taxfixExportId        String?
  taxfixExport          TaxfixExport?  @relation(fields: [taxfixExportId], references: [id])

  notes                 String?        @db.Text
  createdAt             DateTime       @default(now())
  updatedAt             DateTime       @updatedAt

  @@index([clientId])
  @@index([status])
  @@index([type])
  @@index([receiptNumber])
}

model TaxfixExport {
  id                       String       @id @default(cuid())
  exportNumber             String       @unique
  periodStart              DateTime
  periodEnd                DateTime
  totalReceipts            Int
  totalGrossAmount         Decimal      @db.Decimal(10,2)
  totalVatAmount           Decimal      @db.Decimal(10,2)
  totalNetAmount           Decimal      @db.Decimal(10,2)
  exportFileUrl            String?
  exportedAt               DateTime?
  exportedById             String
  status                   ExportStatus @default(DRAFT)
  importedToTaxfixAt       DateTime?
  taxfixInvoicesGenerated  Boolean      @default(false)
  receipts                 PaymentReceipt[]
  createdAt                DateTime     @default(now())
  updatedAt                DateTime     @updatedAt
}

// ── VAGF Models ──

model GuestFeedback {
  id                    String            @id @default(cuid())

  reservationId         String            @unique
  reservation           Reservation       @relation(fields: [reservationId], references: [id], onDelete: Cascade)
  propertyId            String
  property              Property          @relation("PropertyFeedback", fields: [propertyId], references: [id], onDelete: Cascade)
  clientId              String
  client                User              @relation("ClientFeedback", fields: [clientId], references: [id], onDelete: Restrict)
  crewMemberId          String?
  crewMember            User?             @relation("CrewFeedback", fields: [crewMemberId], references: [id], onDelete: SetNull)

  // Call metadata
  callStatus            CallStatus        @default(SCHEDULED)
  callAttempts          Int               @default(0)
  callScheduledAt       DateTime
  callStartedAt         DateTime?
  callEndedAt           DateTime?
  callDurationSeconds   Int?
  language              String            @default("en")

  // External refs
  elevenlabsCallId      String?
  twilioCallSid         String?
  recordingUrl          String?
  transcriptionFull     String?           @db.Text

  // Structured scores (1-10, nullable if not captured)
  // ── PROPERTY dimension (Owner accountability) ──
  scorePropertyStructure  Int?          // Building quality, furniture, bed comfort
  scorePropertyAmenities  Int?          // WiFi, AC, kitchen gear, TV, extras offered
  scoreLocation           Int?          // Location quality and neighbourhood
  scoreValueForMoney      Int?          // Value vs price paid

  // ── CREW dimension (turnover team accountability) ──
  scorePropertyState      Int?          // Condition on arrival (cleanliness + order)
  scoreCleanliness        Int?          // Detailed cleaning quality
  scoreCrewPresentation   Int?          // Welcome, smart lock handoff, first contact

  // ── PLATFORM dimension (HostMasters accountability) ──
  scoreCommunication      Int?          // Pre-arrival info (WiFi, codes, directions)
  scoreCheckInExperience  Int?          // Check-in smoothness
  scoreCheckOutExperience Int?          // Check-out smoothness
  scorePlatformOverall    Int?          // Overall HostMasters experience
  scoreNps                Int?          // Net Promoter Score (0-10)

  // Calculated
  npsCategory           NpsCategory?
  sentimentOverall      FeedbackSentiment @default(NEUTRAL)

  // Qualitative feedback — grouped by accountability dimension
  feedbackFirstImpression String?         @db.Text
  // Property (owner)
  feedbackProperty       String?          @db.Text
  feedbackPropertyPositive String?        @db.Text
  feedbackPropertyImprovement String?     @db.Text
  // Crew (delivery)
  feedbackCrew           String?          @db.Text
  feedbackCrewPositive   String?          @db.Text
  feedbackCrewImprovement String?         @db.Text
  // Platform (HostMasters)
  feedbackPlatform       String?          @db.Text
  feedbackPlatformPositive String?        @db.Text
  feedbackPlatformImprovement String?     @db.Text
  // Generic (kept for legacy)
  feedbackPositive      String?           @db.Text
  feedbackImprovement   String?           @db.Text
  feedbackNegative      String?           @db.Text
  feedbackRecommendation String?          @db.Text

  // Auto-categorization
  categoryTags          String[]

  // Contact during stay
  contactedDuringStay   Boolean           @default(false)
  contactResponseScore  Int?

  // Review workflow
  reviewPromptSent      Boolean           @default(false)
  reviewSmsSent         Boolean           @default(false)
  reviewSmsSentAt       DateTime?

  // Escalation
  escalationTriggered   Boolean           @default(false)
  escalationLevel       EscalationLevel?
  escalationNotifiedTo  String[]

  // Confidence + cross-validation (VAGF pipeline v2)
  analysisConfidence       Float?          // 0.0–1.0 weighted crew-dimension confidence
  analysisCrossValidated   Boolean         @default(false)
  analysisReviewRequired   Boolean         @default(false) // true → queued for Captain review
  analysisReviewedAt       DateTime?
  analysisReviewedBy       String?         // Captain or Admin userId who reviewed

  // Crew score dispute
  scoreDisputed            Boolean         @default(false)
  scoreDisputeReason       String?         @db.Text
  scoreDisputedAt          DateTime?
  scoreDisputeResolvedAt   DateTime?
  scoreDisputeResolvedBy   String?         // Captain/Admin who resolved
  scoreDisputeOutcome      String?         // UPHELD | OVERRIDDEN | ADJUSTED

  // Web fallback token
  webToken              String?           @unique

  createdAt             DateTime          @default(now())
  updatedAt             DateTime          @updatedAt

  @@index([reservationId])
  @@index([crewMemberId])
  @@index([clientId])
  @@index([propertyId])
  @@index([analysisReviewRequired])
  @@index([callStatus])
  @@index([createdAt])
}

model GuestFeedbackCategory {
  id          String            @id @default(cuid())
  tag         String            @unique
  displayName String
  category    String
  sentiment   FeedbackSentiment
  createdAt   DateTime          @default(now())
}

/// Magic-link chat session between a guest and the platform during stay.
/// AI (Claude) handles ~70%. Escalates to Manager → Admin when needed.
model GuestStayChat {
  id                String                    @id @default(cuid())
  reservationId     String                    @unique
  reservation       Reservation               @relation(fields: [reservationId], references: [id], onDelete: Cascade)
  propertyId        String
  property          Property                  @relation("PropertyStayChats", fields: [propertyId], references: [id], onDelete: Cascade)
  clientId          String
  client            User                      @relation("ClientStayChats", fields: [clientId], references: [id], onDelete: Restrict)
  token             String                    @unique

  language          String                    @default("en")
  escalationStatus  StayChatEscalationStatus  @default(NONE)
  escalatedAt       DateTime?
  escalatedToUserId String?
  escalatedTo       User?                     @relation("EscalatedStayChats", fields: [escalatedToUserId], references: [id], onDelete: SetNull)
  resolvedAt        DateTime?

  messageCount      Int                       @default(0)
  lastMessageAt     DateTime?

  createdAt         DateTime                  @default(now())
  updatedAt         DateTime                  @updatedAt

  messages          GuestStayMessage[]

  @@index([reservationId])
  @@index([propertyId])
  @@index([clientId])
  @@index([escalationStatus])
}

model GuestStayMessage {
  id            String         @id @default(cuid())
  chatId        String
  chat          GuestStayChat  @relation(fields: [chatId], references: [id], onDelete: Cascade)
  author        StayChatAuthor
  authorUserId  String?
  content       String         @db.Text
  aiConfidence  Float?
  aiTopicTag    String?
  createdAt     DateTime       @default(now())

  @@index([chatId])
  @@index([createdAt])
}

model Reservation {
  id            String            @id @default(cuid())
  propertyId    String
  guestName     String
  guestEmail    String?
  guestPhone    String?
  checkIn       DateTime
  checkOut      DateTime
  amount        Float
  currency      String            @default("EUR")
  platform      Platform?
  externalId    String?
  status        ReservationStatus @default(UPCOMING)
  notes         String?           @db.Text
  crewReport    String?           @db.Text

  // ── Guest demographics (dados nativos HM) ──
  guestNationality  String?    // ISO 3166-1 alpha-2 (ES, DE, GB, FR, NL...)
  guestCountry      String?    // country name display
  guestAge          Int?       // idade estimada
  guestAgeGroup     String?    // YOUNG_COUPLE | FAMILY | MATURE_COUPLE | GROUP | SOLO | SENIOR
  guestGroupSize    Int?       // número de pessoas
  hasChildren       Boolean?
  hasPets           Boolean?
  isRepeatGuest     Boolean    @default(false)

  // ── SES / Registro de Viajeros (mandatory in Spain) ──
  guestDocumentType   String?    // PASSPORT | DNI | NIE | OTHER
  guestDocumentNumber String?
  guestDateOfBirth    DateTime?  @db.Date
  guestGender         String?    // M | F | OTHER
  guestAddress        String?
  sesSubmittedAt      DateTime?
  sesReference        String?    // reference ID from SES submission
  guestLanguage     String?    // língua principal (es, en, de, fr, nl...)
  bookingLeadDays   Int?       // dias entre booking e check-in (auto-calculado)
  bookingChannel    String?    // DIRECT_PLATFORM | WEBSITE | REFERRAL | REPEAT
