enum PartnerTier {
  STANDARD
  STANDARD_PLUS
  PREMIUM
  STRATEGIC
}

enum PartnerStatus {
  ACTIVE
  INACTIVE
  SUSPENDED
}

model Partner {
  id              String        @id @default(cuid())
  name            String
  businessName    String?
  email           String?
  phone           String?
  tier            PartnerTier   @default(STANDARD)
  referralCode    String        @unique
  status          PartnerStatus @default(ACTIVE)
  commissionFixed Decimal?      @db.Decimal(10,2)
  commissionPct   Decimal?      @db.Decimal(5,2)
  totalReferrals  Int           @default(0)
  totalConversions Int          @default(0)
  totalCommission Decimal       @default(0) @db.Decimal(10,2)
  zone            String?
  notes           String?
  // Auth fields for partner portal
  passwordHash    String?
  loginToken      String?       @unique
  lastLoginAt     DateTime?
  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @updatedAt

  leads           Lead[]        @relation("PartnerLeads")
  payouts         PartnerPayout[]
}

enum PartnerPayoutStatus {
  PENDING       // 30-day holding period
  APPROVED      // Ready to pay
  PAID          // Paid out
  REVERSED      // Client cancelled within 60 days
}

model PartnerPayout {
  id               String              @id @default(cuid())
  partnerId        String
  partner          Partner             @relation(fields: [partnerId], references: [id])
  leadId           String              @unique
  lead             Lead                @relation(fields: [leadId], references: [id], onDelete: Cascade)
  clientName       String?
  amount           Decimal             @db.Decimal(10,2)
  status           PartnerPayoutStatus @default(PENDING)
  holdUntil        DateTime            // 30 days after conversion
  reversalDeadline DateTime            // 60 days after conversion
  paidAt           DateTime?
  reversedAt       DateTime?
  notes            String?
  createdAt        DateTime            @default(now())
  updatedAt        DateTime            @updatedAt

  @@index([partnerId])
  @@index([status])
}

enum ManagerPayoutStatus {
  PENDING       // Calculated, awaiting admin approval
  APPROVED      // Approved for transfer
  PAID          // Transfer completed
  CANCELLED     // Manually cancelled
}

/// Monthly manager commission payout.
/// - Created by cron on/around day 10 of each month for the prior month
/// - Covers: 15% subscription share + 3% gross rental share + portfolio bonus
///   + acquisition bonuses for clients activated 2 months ago
model ManagerPayout {
  id                   String              @id @default(cuid())
  managerId            String
  manager              User                @relation("ManagerPayouts", fields: [managerId], references: [id])
  periodYear           Int                 // e.g. 2026
  periodMonth          Int                 // 1..12 (the month being paid for)
  subscriptionEarnings Decimal             @db.Decimal(10,2)  // 15% of client subscriptions actually paid this month
  rentalEarnings       Decimal             @db.Decimal(10,2)  // 3% of gross rental revenue this month
  portfolioBonus       Decimal             @db.Decimal(10,2)  // 150/400/750 tier bonus
  acquisitionBonus     Decimal             @db.Decimal(10,2)  // sum of one-time bonuses for clients activated 2 months ago
  finalAmount          Decimal             @db.Decimal(10,2)  // sum of above 4
  breakdown            Json?               // detail lines: clients, properties, bonuses
  clientCount          Int                 @default(0)
  activePropertyCount  Int                 @default(0)
  status               ManagerPayoutStatus @default(PENDING)
  payBy                DateTime            // day 10 of the following month
  paidAt               DateTime?
  cancelledAt          DateTime?
  stripeTransferId     String?             // if paid via Stripe Connect
  statementSentAt      DateTime?           // email statement timestamp
  notes                String?             @db.Text
  createdAt            DateTime            @default(now())
  updatedAt            DateTime            @updatedAt

  @@unique([managerId, periodYear, periodMonth])
  @@index([managerId])
  @@index([status])
  @@index([periodYear, periodMonth])
}

enum RecruitRole {
  MANAGER
  CREW
}

enum RecruitStatus {
  NEW
  CONTACTED
  INTERVIEWING
  ACCEPTED
  REJECTED
}

model RecruitApplication {
  id             String         @id @default(cuid())
  role           RecruitRole
  name           String
  email          String
  phone          String?
  // Location
  zone           String?        // e.g. "Almunecar", "Nerja", "Salobrena"
  // Manager-specific
  languages      String[]       // ["en", "sv", "no"]
  experience     String?        @db.Text
  // Crew-specific
  skills         String[]       // ["CLEANING", "MAINTENANCE", "CHECK_IN"]
  availability   String?        // "full-time" | "part-time" | "weekends"
  // Common
  message        String?        @db.Text
  source         String?        // utm_source or "landing"
  locale         String?        // browser locale when submitted
  status             RecruitStatus  @default(NEW)
  reviewedAt         DateTime?
  reviewedById       String?
  adminNotes         String?        @db.Text
  convertedToUserId  String?        // set when converted into a real User via invite
  convertedAt        DateTime?
  createdAt          DateTime       @default(now())
  updatedAt          DateTime       @updatedAt

  @@index([role, status])
  @@index([createdAt])
}

// ─── Notifications ──────────────────────────────────────────────────────────

enum NotificationType {
  // Tasks
  TASK_ASSIGNED
  TASK_CONFIRMED
  TASK_SUBMITTED
  TASK_APPROVED
  TASK_REJECTED
  TASK_REDISTRIBUTED
  // Crew
  CREW_PAYOUT_READY
  CREW_PAYOUT_PAID
  CREW_PAYOUT_FAILED
  CREW_SCORE_CHANGE
  CREW_LEVEL_UP
  CREW_LEVEL_DOWN
  // Manager
  NEW_LEAD
  CLIENT_REGISTERED
  CLIENT_PROPERTY_APPROVED
  COMMISSION_STATEMENT
  COMMISSION_PAID
  // Client
  PROPERTY_APPROVED
  CONTRACT_READY
  PROPERTY_ACTIVE
  BOOKING_RECEIVED
  RESERVATION_CANCELLED
  PAYOUT_COMPLETED
  VISIT_COMPLETED
  TAX_DEADLINE
  // Broadcast (founder ↔ subscribers)
  BROADCAST_RECEIVED
  BROADCAST_REPLY
  // System
  INTERVENTION_OPENED
  INTERVENTION_RESOLVED
  AI_ALERT
  GENERAL
}

model Notification {
  id        String           @id @default(cuid())
  userId    String
  type      NotificationType @default(GENERAL)
  title     String
  body      String?          @db.Text
  link      String?
  read      Boolean          @default(false)
  readAt    DateTime?
  count     Int              @default(1)  // batched events of same (type, link)
  createdAt DateTime         @default(now())
  updatedAt DateTime         @default(now()) @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, read, createdAt])
  @@index([userId, type, link, read, createdAt])
  @@index([createdAt])
}

// ─── Stay Reviews (Guest Review scoring) ────────────────────────────────────

model StayReview {
  id                String    @id @default(cuid())
  reservationId     String    @unique
  reservation       Reservation @relation(fields: [reservationId], references: [id])
  propertyId        String
  property          Property  @relation(fields: [propertyId], references: [id])
  reviewerId        String
  reviewer          User      @relation("StayReviewer", fields: [reviewerId], references: [id])

  cleaningRating    Int       // 1-5, WEIGHT 3
  setupRating       Int       // 1-5, WEIGHT 2
  conditionRating   Int       // 1-5, WEIGHT 1
  overallRating     Decimal   @db.Decimal(3,2) // calculated weighted average

  guestComments     String?   @db.Text
  issuesReported    String?   @db.Text

  crewMemberId      String?   // Crew who did the cleaning/checkout
  scoreApplied      Boolean   @default(false)

  createdAt         DateTime  @default(now())

  @@index([propertyId])
  @@index([crewMemberId])
}

// ─── Consumables & Stock Management ─────────────────────────────────────────

model ConsumableCategory {
  id                String          @id @default(cuid())
  name              String
  type              ConsumableType
  unit              String          @default("unit")
  standardLifecycle Int?
  imageUrl          String?
  active            Boolean         @default(true)
  createdAt         DateTime        @default(now())

  items             ConsumableItem[]
  propertySetups    PropertyConsumableSetup[]
  stockLevel        StockLevel?
}

model ConsumableItem {
  id                String          @id @default(cuid())
  categoryId        String
  category          ConsumableCategory @relation(fields: [categoryId], references: [id])
  serialNumber      String?         @unique
  batchNumber       String?
  status            ItemStatus      @default(AVAILABLE)
  currentPropertyId String?
  currentProperty   Property?       @relation(fields: [currentPropertyId], references: [id])
  washCount         Int             @default(0)
  purchaseDate      DateTime        @default(now())
  purchasePrice     Decimal         @db.Decimal(10, 2)
  expectedLifespan  Int?
  retiredAt         DateTime?
  retireReason      String?
  createdAt         DateTime        @default(now())
  updatedAt         DateTime        @updatedAt

  movements         ConsumableMovement[]

  @@index([categoryId])
  @@index([status])
}

model ConsumableMovement {
  id                String          @id @default(cuid())
  itemId            String
  item              ConsumableItem  @relation(fields: [itemId], references: [id])
  movementType      MovementType
  fromLocation      String?
  toLocation        String?
  propertyId        String?
  property          Property?       @relation(fields: [propertyId], references: [id])
  crewMemberId      String?
  reservationId     String?
  quantity          Int             @default(1)
  executedAt        DateTime        @default(now())
  notes             String?

  @@index([itemId])
  @@index([executedAt])
}

model PropertyConsumableSetup {
  id                String          @id @default(cuid())
  propertyId        String
  property          Property        @relation(fields: [propertyId], references: [id])
  categoryId        String
  category          ConsumableCategory @relation(fields: [categoryId], references: [id])
  quantityPerStay   Int
  notes             String?
  active            Boolean         @default(true)
  createdAt         DateTime        @default(now())
  updatedAt         DateTime        @updatedAt

  @@unique([propertyId, categoryId])
}

model StockLevel {
  id                String          @id @default(cuid())
  categoryId        String          @unique
  category          ConsumableCategory @relation(fields: [categoryId], references: [id])
  totalItems        Int             @default(0)
  available         Int             @default(0)
  deployed          Int             @default(0)
  inLaundry         Int             @default(0)
  inTransit         Int             @default(0)
  quarantine        Int             @default(0)
  retired           Int             @default(0)
  minimumLevel      Int             @default(0)
  criticalLevel     Int             @default(0)
  lastUpdated       DateTime        @updatedAt
}

// ── Founder broadcasts (one-way email channel from admin → subscribers) ──
model Broadcast {
  id              String           @id @default(cuid())
  senderId        String?
  sender          User?            @relation("BroadcastSender", fields: [senderId], references: [id], onDelete: SetNull)
  subject         String
  bodyMarkdown    String           @db.Text
  ctaText         String?
  ctaUrl          String?
  audienceType    BroadcastAudience @default(ALL_PAID)
  audienceValue   String?          // plan name, language code, etc. depending on audienceType
  status          BroadcastStatus  @default(DRAFT)
  sentAt          DateTime?
  recipientCount  Int              @default(0)
  failedCount     Int              @default(0)
  translations    Json?            // cached translations per locale: { "pt": {...}, "en": {...} }
  createdAt       DateTime         @default(now())
  updatedAt       DateTime         @updatedAt

  recipients      BroadcastRecipient[]
  replies         BroadcastReply[]

  @@index([senderId])
  @@index([sentAt])
}

model BroadcastRecipient {
  id            String   @id @default(cuid())
  broadcastId   String
  broadcast     Broadcast @relation(fields: [broadcastId], references: [id], onDelete: Cascade)
  userId        String
  user          User     @relation("BroadcastRecipient", fields: [userId], references: [id], onDelete: Cascade)
  language      String   // locale this user received the broadcast in
  delivered     Boolean  @default(true)
  readAt        DateTime?
  createdAt     DateTime @default(now())

  @@unique([broadcastId, userId])
  @@index([userId, readAt])
}

model BroadcastReply {
  id              String   @id @default(cuid())
  broadcastId     String
  broadcast       Broadcast @relation(fields: [broadcastId], references: [id], onDelete: Cascade)
  threadOwnerId   String   // the subscriber the thread belongs to (groups admin↔client messages)
  threadOwner     User     @relation("BroadcastThreadOwner", fields: [threadOwnerId], references: [id])
  authorId        String   // who wrote this specific message (subscriber OR admin)
  author          User     @relation("BroadcastReplyAuthor", fields: [authorId], references: [id])
  bodyText        String   @db.Text
  readAt          DateTime?
  createdAt       DateTime @default(now())

  @@index([broadcastId, threadOwnerId])
}

enum BroadcastStatus {
  DRAFT
  SENDING
  SENT
  FAILED
}

enum BroadcastAudience {
  ALL_PAID       // all CLIENT users with subscriptionPlan != STARTER
  ALL_CLIENTS    // all CLIENT users (any plan, including Starter)
  BY_PLAN        // audienceValue = 'BASIC' | 'MID' | 'PREMIUM'
  BY_LANGUAGE    // audienceValue = locale code
}
