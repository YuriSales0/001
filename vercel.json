{
  "buildCommand": "npx prisma generate && npx prisma db push --accept-data-loss && npx tsx prisma/seed.ts && next build",
  "framework": "nextjs",
  "crons": [
    {
      "path": "/api/cron/monthly-statements",
      "schedule": "0 8 1 * *"
    },
    {
      "path": "/api/cron/ai-monitor",
      "schedule": "0 7 * * *"
    },
    {
      "path": "/api/cron/scrape-market",
      "schedule": "0 6 * * 0"
    },
    {
      "path": "/api/cron/crew-payout",
      "schedule": "0 9 * * 3"
    },
    {
      "path": "/api/cron/crew-confirmation-timeout",
      "schedule": "*/10 * * * *"
    },
    {
      "path": "/api/cron/notification-cleanup",
      "schedule": "0 3 * * *"
    }
  ]
}
